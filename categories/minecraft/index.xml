&gt;&lt;/p&gt;
&lt;p&gt;&lt;img src=&#34;https://5itomato.github.io/p/minecraft-tutorial/8.png&#34;
	width=&#34;2560&#34;
	height=&#34;1518&#34;
	srcset=&#34;https://5itomato.github.io/p/minecraft-tutorial/8_hu3169600369670796918.png 480w, https://5itomato.github.io/p/minecraft-tutorial/8_hu11722676322833138042.png 1024w&#34;
	loading=&#34;lazy&#34;
	
	
		class=&#34;gallery-image&#34; 
		data-flex-grow=&#34;168&#34;
		data-flex-basis=&#34;404px&#34;
	
&gt;&lt;/p&gt;
